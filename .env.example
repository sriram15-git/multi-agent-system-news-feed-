# =========================================================================
#             AI NEWS DIGEST PIPELINE - ENVIRONMENT CONFIGURATION
# =========================================================================
# Copy this file to a new file named '.env' and fill in your actual credentials.
# The '.env' file should be placed in the project root directory.

# -------------------------------------------------------------------------
# 1. GMAIL CONFIGURATION (For sending the newsletter)
# -------------------------------------------------------------------------
# Your full Gmail address from which the newsletter will be sent.
GMAIL_ADDRESS=your.email@gmail.com

# Your 16-character Google App Password (NOT your standard email password!).
# How to get it:
# 1. Go to your Google Account (https://myaccount.google.com)
# 2. Navigate to "Security"
# 3. Enable "2-Step Verification" (if not already enabled)
# 4. Search for "App Passwords" or go to the App Passwords section
# 5. Create a new App Password (select "Mail" and "Other (Custom name)")
# 6. Copy the generated 16-character code (e.g., "abcd efgh ijkl mnop")
# 7. Paste it below without spaces.
GMAIL_APP_PASSWORD=abcdefghijklmnop

# Comma-separated list of recipient email addresses.
RECIPIENTS=recipient1@gmail.com,recipient2@yahoo.com


# -------------------------------------------------------------------------
# 2. LLM / AI MODEL PROVIDER CONFIGURATION
# -------------------------------------------------------------------------
# Option A: Cloud Deployment / No local setup (RECOMMENDED FOR RENDER/PRODUCTION)
# Get a 100% free Gemini API key from Google AI Studio: https://aistudio.google.com/
# If this key is provided, the pipeline will automatically use Gemini (lightweight, fast, no local server needed).
GEMINI_API_KEY=AIzaSy...your-actual-api-key-here...

# Option B: Local Ollama setup (Defaults if GEMINI_API_KEY is left blank)
# Make sure Ollama is installed locally (https://ollama.com) and running ('ollama serve').
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_HOST=http://localhost:11434


# -------------------------------------------------------------------------
# 3. PIPELINE SCHEDULER & DEPLOYMENT SETTINGS
# -------------------------------------------------------------------------
# Time of day to run the pipeline daily (in local/scheduler timezone).
DAILY_HOUR=11
DAILY_MINUTE=0

# Weather Location Settings
WEATHER_CITY=Vellore
WEATHER_LATITUDE=12.9165
WEATHER_LONGITUDE=79.1325

# Humor mode personality for the digest
# Available options: sarcastic | funny | roast | gen-z | professional
HUMOR_MODE=sarcastic
